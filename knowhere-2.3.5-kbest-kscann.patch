diff --git a/src/index/kbest/kbest.cc b/src/index/kbest/kbest.cc
new file mode 100644
index 0000000..8ffe79f
--- /dev/null
+++ b/src/index/kbest/kbest.cc
@@ -0,0 +1,300 @@
+#include "index/kbest/kbest_config.h"
+#include "kbest.h"
+
+#include <numa.h>
+#include <limits>
+
+#include "knowhere/comp/index_param.h"
+#include "knowhere/comp/thread_pool.h"
+#include "knowhere/comp/time_recorder.h"
+#include "knowhere/config.h"
+#include "knowhere/expected.h"
+#include "knowhere/index/index_factory.h"
+#include "knowhere/index/index_node_data_mock_wrapper.h"
+#include "knowhere/log.h"
+#include "knowhere/range_util.h"
+#include "knowhere/utils.h"
+#include "io/memory_io.h"
+
+namespace knowhere {
+
+template <typename DataType>
+
+class KbestIndexNode : public IndexNode {
+public:
+
+    KbestIndexNode(const int32_t& /* version */, const Object& object) : indexSize_(0),
+                                                                         index_(nullptr),
+                                                                         data_(nullptr) {}
+
+    Status Train(const DataSet& dataset, const Config& cfg) override {
+        NUMA_ENABLED = false;
+        auto dim = dataset.GetDim();
+        auto kbest_cfg = static_cast<const KbestConfig&>(cfg);
+        auto index = new (std::nothrow) KBest((int)dim, kbest_cfg.R.value(), kbest_cfg.L.value(), kbest_cfg.A.value(),
+                                              kbest_cfg.metric_type.value().c_str(),
+                                              kbest_cfg.init_builder_type.value());
+        if (index == nullptr) {
+            LOG_KNOWHERE_WARNING_ << "memory malloc error.";
+            return Status::malloc_error;
+        }
+        if (this->index_) {
+            delete this->index_;
+            this->index_ = nullptr;
+            LOG_KNOWHERE_WARNING_ << "index not empty, deleted old index.";
+        }
+        this->index_ = index;
+        return Status::success;
+    }
+
+    void normalize(float *data, int length) {
+        float norm = 0.0f;
+        for (int i = 0; i < length; ++i) {
+            norm += data[i] * data[i];
+        }
+        norm = std::sqrt(norm);
+        if (std::fabs(norm) > std::numeric_limits<float>::epsilon()) {
+            for (int i = 0; i < length; ++i) {
+                data[i] /= norm;
+                assert(!isnan(data[i]));
+            }
+        }
+    }
+
+    Status Add(const DataSet& dataset, const Config& cfg) override {
+        if (!index_) {
+            LOG_KNOWHERE_ERROR_ << "Can not add data to empty KBEST index.";
+            return Status::empty_index;
+        }
+
+        auto rows = dataset.GetRows();
+        if (rows <= 0) {
+            LOG_KNOWHERE_ERROR_ << "Can not add empty data to KBEST index.";
+            return Status::empty_index;
+        }
+
+        auto dim = dataset.GetDim();
+        auto kbest_cfg = static_cast<const KbestConfig&>(cfg);
+        int consecutiveLog = kbest_cfg.consecutive.value();
+        int level = kbest_cfg.level.value();
+
+        float *data = const_cast<float *>(static_cast<const float *>(dataset.GetTensor()));
+        data_ = new (std::nothrow) float[dim * rows];
+        if (data_ == nullptr) {
+            LOG_KNOWHERE_WARNING_ << "failed to create data.";
+            return Status::index_not_trained;
+        }
+        memcpy(data_, data, dim * rows * sizeof(float));
+
+        if (kbest_cfg.metric_type.value() == "IP") {
+            for (int i = 0; i < rows; ++i) {
+                normalize(data_ + i * dim, dim);
+            }
+        }
+
+        if (index_->Add(rows, data_, consecutiveLog, level) != 0) {
+            LOG_KNOWHERE_WARNING_ << "failed to build.";
+            return Status::index_not_trained;
+        }
+        index_->BuildSearcher();
+        return Status::success;
+    }
+
+    expected<DataSetPtr> Search(const DataSet& dataset, const Config& cfg, const BitsetView& bitset) const override {
+        if (!index_) {
+            LOG_KNOWHERE_WARNING_ << "Search on empty index.";
+            return expected<DataSetPtr>::Err(Status::empty_index, "index not loaded");
+        }
+
+        auto dim = dataset.GetDim();
+        auto rows = dataset.GetRows();
+        float *data = const_cast<float *>(static_cast<const float *>(dataset.GetTensor()));
+        auto kbest_cfg = static_cast<const KbestConfig&>(cfg);
+        int closestNum = kbest_cfg.k.value();
+
+        if (kbest_cfg.metric_type.value() == "IP") {
+            for (int i = 0; i < rows; ++i) {
+                float norm = 0.0f;
+                float *tmp = data + i * dim;
+                for (int j = 0; j < dim; ++j) {
+                    norm += tmp[j] * tmp[j];
+                }
+                norm = std::sqrt(norm);
+                if (std::fabs(norm) > std::numeric_limits<float>::epsilon()) {
+                    for (int j = 0; j < dim; ++j) {
+                        tmp[j] /= norm;
+                        assert(!isnan(tmp[j]));
+                    }
+                }
+            }
+        }
+
+        if (index_->SetEf(kbest_cfg.efs.value()) != 0) {
+            LOG_KNOWHERE_WARNING_ << "failed to set ef.";
+            return expected<DataSetPtr>::Err(Status::not_implemented, "SetEf not implemented");
+        }
+
+        float *distances = new (std::nothrow) float[rows * closestNum]();
+        if (distances == nullptr) {
+            LOG_KNOWHERE_WARNING_ << "failed to create distances.";
+            return expected<DataSetPtr>::Err(Status::not_implemented, "Search not implemented");
+        }
+
+        int64_t *labels = new (std::nothrow) int64_t[rows * closestNum]();
+        if (labels == nullptr) {
+            delete[] distances;
+            distances = nullptr;
+            LOG_KNOWHERE_WARNING_ << "failed to create labels, free memory space.";
+            return expected<DataSetPtr>::Err(Status::not_implemented, "Search not implemented");
+        }
+
+        if (index_->Search(rows, data, closestNum, distances, labels,
+                           kbest_cfg.num_search_thread.value()) != 0) {
+            delete[] distances;
+            distances = nullptr;
+            delete[] labels;
+            labels = nullptr;
+            LOG_KNOWHERE_WARNING_ << "failed to search, free memory space.";
+            return expected<DataSetPtr>::Err(Status::not_implemented, "Search not implemented");
+        }
+
+        auto res = GenResultDataSet(rows, closestNum, labels, const_cast<const float *>(distances));
+        return res;
+    }
+
+    expected<DataSetPtr> GetVectorByIds(const DataSet& dataset) const override {
+        return expected<DataSetPtr>::Err(Status::not_implemented, "GetVectorByIds not implemented");
+    }
+
+    bool HasRawData(const std::string& metric_type) const override {
+        // 未实现 GetVectorByIds，直接返回 false
+        return false;
+    }
+
+    expected<DataSetPtr> GetIndexMeta(const Config& cfg) const override {
+        if (!index_) {
+            LOG_KNOWHERE_WARNING_ << "get index meta on empty index.";
+            return expected<DataSetPtr>::Err(Status::empty_index, "index not loaded");
+        }
+        return expected<DataSetPtr>::Err(Status::not_implemented, "GetIndexMeta not implemented");
+    }
+
+    Status Serialize(BinarySet& binset) const override {
+        if (!index_) {
+            LOG_KNOWHERE_WARNING_ << "Can not serialize empty KBEST index.";
+            return Status::empty_index;
+        }
+
+        uint8_t *dataPtr = nullptr;
+        size_t dataLength = 0;
+        try {
+            MemoryIOWriter writer;
+
+            if (index_->Serialize(dataPtr, dataLength) != 0) {
+                LOG_KNOWHERE_WARNING_ << "failed to serialize KBEST index.";
+                return Status::not_implemented;
+            }
+            writer.write((char *)dataPtr, dataLength);
+            delete[] dataPtr;
+            dataPtr = nullptr;
+
+            std::shared_ptr<uint8_t[]> data(writer.data());
+            binset.Append(Type(), data, writer.tellg());
+        } catch (std::exception& e) {
+            if (dataPtr) {
+                delete[] dataPtr;
+                dataPtr = nullptr;
+            }
+            LOG_KNOWHERE_WARNING_ << "kbest inner error: " << e.what();
+            return Status::not_implemented;
+        }
+        return Status::success;
+    }
+
+    Status Deserialize(const BinarySet& binset, const Config& config) override {
+        if (index_) {
+            delete index_;
+            index_ = nullptr;
+            LOG_KNOWHERE_WARNING_ << "index not empty, deleted old index.";
+        }
+
+        try {
+            auto binary = binset.GetByName(Type());
+            if (binary == nullptr) {
+                LOG_KNOWHERE_WARNING_ << "Invalid binary set.";
+                return Status::invalid_binary_set;
+            }
+            indexSize_ = binary->size;
+
+            index_ = new (std::nothrow) KBest();
+            if (index_ == nullptr) {
+                LOG_KNOWHERE_WARNING_ << "failed to create KBEST index.";
+                return Status::not_implemented;
+            }
+
+            if (index_->Deserialize(binary->data.get(), binary->size) != 0) {
+                LOG_KNOWHERE_WARNING_ << "failed to deserialize KBEST index.";
+                return Status::not_implemented;
+            }
+            LOG_KNOWHERE_INFO_ << "Loaded KBEST index.";
+        } catch (std::exception& e) {
+            LOG_KNOWHERE_WARNING_ << "kbest inner error: " << e.what();
+            return Status::not_implemented;
+        }
+        return Status::success;
+    }
+
+    Status DeserializeFromFile(const std::string& filename, const Config& config) override {
+        return Status::not_implemented;
+    }
+
+    std::unique_ptr<BaseConfig> CreateConfig() const override {
+        NUMA_ENABLED = false;
+        return std::make_unique<KbestConfig>();
+    }
+
+    int64_t Dim() const override {
+        if (!index_) {
+            return 0;
+        }
+        return index_->GetDim();
+    }
+
+    int64_t Size() const override {
+        if (!index_) {
+            return 0;
+        }
+        return indexSize_;
+    }
+
+    int64_t Count() const override {
+        if (!index_) {
+            return 0;
+        }
+        return index_->GetNTotal();
+    }
+
+    std::string Type() const override {
+        return knowhere::IndexEnum::INDEX_KBEST;
+    }
+
+    ~KbestIndexNode() override {
+        if (data_) {
+            delete[] data_;
+            data_ = nullptr;
+        }
+        if (index_) {
+            delete index_;
+            index_ = nullptr;
+        }
+    }
+
+private:
+    int64_t indexSize_;
+    KBest *index_;
+    float *data_;
+};
+
+KNOWHERE_SIMPLE_REGISTER_GLOBAL(KBEST, KbestIndexNode, fp32);
+
+}   // namespace knowhere
\ No newline at end of file
diff --git a/src/index/kbest/kbest_config.h b/src/index/kbest/kbest_config.h
new file mode 100644
index 0000000..0436b41
--- /dev/null
+++ b/src/index/kbest/kbest_config.h
@@ -0,0 +1,138 @@
+#ifndef KBEST_CONFIG_H
+#define KBEST_CONFIG_H
+
+#include "knowhere/comp/index_param.h"
+#include "knowhere/config.h"
+
+namespace knowhere {
+
+namespace {
+
+constexpr const CFG_INT::value_type kEfMinValues = 16;
+
+}   // namespace
+
+class KbestConfig : public BaseConfig {
+public:
+    CFG_INT R;
+    CFG_INT L;
+    CFG_INT A;
+    CFG_STRING build_index_type;
+    CFG_STRING init_builder_type;
+    CFG_INT graph_opt_iter;
+    CFG_BOOL reorder;
+    CFG_INT consecutive;
+    CFG_INT level;
+    CFG_INT efs;
+    CFG_INT num_search_thread;
+    CFG_INT adding_pref;
+    CFG_INT patience;
+
+    KNOHWERE_DECLARE_CONFIG(KbestConfig) {
+        KNOWHERE_CONFIG_DECLARE_FIELD(R)
+            .description("kbest R")
+            .set_default(50)
+            .set_range(11, 499)
+            .for_train();
+        KNOWHERE_CONFIG_DECLARE_FIELD(L)
+            .description("kbest efConstruction")
+            .set_default(100)
+            .set_range(11, 1999)
+            .for_train();
+        KNOWHERE_CONFIG_DECLARE_FIELD(A)
+            .description("kbest angle threshold")
+            .set_default(60)
+            .set_range(10, 360)
+            .for_train();
+        KNOWHERE_CONFIG_DECLARE_FIELD(build_index_type)
+            .description("kbest index type[HNSW/SSG/NSG/TSDG]")
+            .allow_empty_without_default()
+            .for_train();
+        KNOWHERE_CONFIG_DECLARE_FIELD(init_builder_type)
+            .description("kbest builder type[NNDescent/RNNDescent]")
+            .allow_empty_without_default()
+            .for_train();
+        KNOWHERE_CONFIG_DECLARE_FIELD(graph_opt_iter)
+            .description("kbest graph link iter num")
+            .set_default(1)
+            .set_range(0, 30)
+            .for_train();
+        KNOWHERE_CONFIG_DECLARE_FIELD(reorder)
+            .description("kbest reorder")
+            .set_default(true)
+            .for_train();
+        KNOWHERE_CONFIG_DECLARE_FIELD(consecutive)
+            .description("kbest block")
+            .set_default(20)
+            .set_range(1, 31)
+            .for_train();
+        KNOWHERE_CONFIG_DECLARE_FIELD(level)
+            .description("kbest qLevel")
+            .set_default(2)
+            .set_range(0, 3)
+            .for_train();
+        KNOWHERE_CONFIG_DECLARE_FIELD(efs)
+            .description("kbest efSearch")
+            .allow_empty_without_default()
+            .set_range(1, std::numeric_limits<CFG_INT::value_type>::max())
+            .for_search();
+        KNOWHERE_CONFIG_DECLARE_FIELD(num_search_thread)
+            .description("index thread limit for search")
+            .allow_empty_without_default()
+            .set_range(1, kHardwareConcurrency)
+            .for_search();
+        KNOWHERE_CONFIG_DECLARE_FIELD(adding_pref)
+            .description("kbest adding_pref")
+            .set_default(52)
+            .set_range(1, std::numeric_limits<CFG_INT::value_type>::max())
+            .for_search();
+        KNOWHERE_CONFIG_DECLARE_FIELD(patience)
+            .description("kbest patience")
+            .set_default(80)
+            .set_range(1, std::numeric_limits<CFG_INT::value_type>::max())
+            .for_search();
+    }
+
+    Status
+    CheckAndAdjust(PARAM_TYPE param_type, std::string* err_msg) override {
+        switch (param_type) {
+            case PARAM_TYPE::TRAIN: {
+                if (!build_index_type.has_value()) {
+                    build_index_type = "SSG";
+                } else if (build_index_type != "SSG" && build_index_type != "NSG" &&
+                           build_index_type != "TSDG" && build_index_type != "HNSW") {
+                    *err_msg = "build_index_type should be SSG or NSG or TSDG or HNSW";
+                    LOG_KNOWHERE_ERROR_ << *err_msg;
+                    return Status::out_of_range_in_json;
+                }
+                if (!init_builder_type.has_value()) {
+                    init_builder_type = "RNNDescent";
+                } else if (init_builder_type != "RNNDescent" && init_builder_type != "NNDescent") {
+                    *err_msg = "init_builder_type should be RNNDescent or NNDescent";
+                    LOG_KNOWHERE_ERROR_ << *err_msg;
+                    return Status::out_of_range_in_json;
+                }
+            }
+            case PARAM_TYPE::SEARCH: {
+                if (!efs.has_value()) {
+                    efs = std::max(k.value(), kEfMinValues);
+                } else if (k.value() > efs.value()) {
+                    *err_msg = "efs(" + std::to_string(efs.value()) + ") should be larger than k(" +
+                               std::to_string(k.value()) + ")";
+                    LOG_KNOWHERE_ERROR_ << *err_msg;
+                    return Status::out_of_range_in_json;
+                }
+                if (!num_search_thread.has_value()) {
+                    num_search_thread = 1;
+                }
+                break;
+            }
+            default:
+                break;
+        }
+        return Status::success;
+    }
+};
+}   // namespace knowhere
+
+#endif	/* KBEST_CONFIG_H */
diff --git a/src/index/kscann/kscann.cc b/src/index/kscann/kscann.cc

+++ b/src/index/kscann/kscann.cc
@@ -0,0 +1,376 @@
+#include "index/kscann/kscann_config.h"
+#include "scann/scann_ops/cc/scann.h"
+#include "scann/proto/scann.pb.h"
+#include "cmdline.h"
+
+#include <numa.h>
+#include <cstdlib>
+#include <limits>
+#include <pybind11/embed.h>
+#include <filesystem>
+
+#include "knowhere/comp/index_param.h"
+#include "knowhere/comp/thread_pool.h"
+#include "knowhere/comp/time_recorder.h"
+#include "knowhere/config.h"
+#include "knowhere/expected.h"
+#include "knowhere/index/index_factory.h"
+#include "knowhere/index/index_node_data_mock_wrapper.h"
+#include "knowhere/log.h"
+#include "knowhere/range_util.h"
+#include "knowhere/utils.h"
+#include "io/memory_io.h"
+
+using namespace research_scann;
+
+namespace knowhere {
+
+namespace py = pybind11;
+namespace fs = std::filesystem;
+
+template <typename DataType>
+
+class KscannIndexNode : public IndexNode {
+public:
+
+    KscannIndexNode(const int32_t& /* version */, const Object& object) : indexSize_(0),
+                                                                          index_(nullptr),
+                                                                          data_(nullptr) {}
+
+    Status Train(const DataSet& dataset, const Config& cfg) override {
+        ScannInterface *index = new (std::nothrow) ScannInterface();
+        if (index == nullptr) {
+            LOG_KNOWHERE_WARNING_ << "memory malloc error.";
+            return Status::malloc_error;
+        }
+        if (this->index_) {
+            delete this->index_;
+            this->index_ = nullptr;
+            LOG_KNOWHERE_WARNING_ << "index not empty, deleted old index.";
+        }
+        this->index_ = index;
+        return Status::success;
+    }
+
+    void normalizeVector(float *data, int size) {
+        float norm = 0.0f;
+        for (int i = 0; i < size; ++i) {
+            norm += data[i] * data[i];
+        }
+        norm = std::sqrt(norm);
+        if (std::fabs(norm) <= std::numeric_limits<float>::epsilon()) {
+            for (int i = 0; i < size; ++i) {
+                data[i] = 1.0f / std::sqrt(size);
+            }
+        } else {
+            for (int i = 0; i < size; ++i) {
+                data[i] /= norm;
+            }
+        }
+    }
+
+    Status Add(const DataSet& dataset, const Config& cfg) override {
+        if (!index_) {
+            LOG_KNOWHERE_ERROR_ << "Can not add data to empty KScaNN index.";
+            return Status::empty_index;
+        }
+
+        auto rows = dataset.GetRows();
+        if (rows <= 0) {
+            LOG_KNOWHERE_ERROR_ << "Can not add empty data to KScaNN index.";
+            return Status::empty_index;
+        }
+
+        auto dim = dataset.GetDim();
+        auto kscann_cfg = static_cast<const KscannConfig&>(cfg);
+
+        float *data = const_cast<float *>(static_cast<const float *>(dataset.GetTensor()));
+        data_ = new (std::nothrow) float[dim * rows];
+        if (data_ == nullptr) {
+            LOG_KNOWHERE_WARNING_ << "failed to create data.";
+            return Status::index_not_trained;
+        }
+        memcpy(data_, data, dim * rows * sizeof(float));
+
+        bool spherical = true;
+        std::string metric_type = "";
+        if (kscann_cfg.metric_type.value() == "L2") {
+            metric_type = "squared_l2";
+            spherical = false;
+        } else if (kscann_cfg.metric_type.value() == "IP") {
+            metric_type = "dot_product";
+            for (int i = 0; i < rows; ++i) {
+                normalizeVector(data_ + i * dim, dim);
+            }
+        } else {
+            LOG_KNOWHERE_WARNING_ << "Unsupported metric type!";
+            return Status::index_not_trained;
+        }
+        ConstSpan<float> data_init(data_, rows * dim);
+
+        const char *var_name = "OPEN_SCANN_INCLUDE";
+        const char *var_value = std::getenv(var_name);
+        if (var_value == nullptr || !fs::exists(var_value) || !fs::is_directory(var_value)) {
+            LOG_KNOWHERE_WARNING_ << "failed to get the path of the create_config.py file!";
+            LOG_KNOWHERE_WARNING_ << "It should be in ${OPEN_SCANN_INCLUDE}.";
+            return Status::index_not_trained;
+        }
+
+        py::scoped_interpreter guard{};
+        py::module_ sys = py::module_::import("sys");
+        sys.attr("path").attr("append")(var_value);
+        std::string config;
+
+        try {
+            py::module_ scann_module = py::module_::import("create_config");
+            py::object scann_configer = scann_module.attr("ScannConfiger");
+            py::object result = scann_configer(dim, kscann_cfg.k.value(), metric_type)
+                .attr("tree")(kscann_cfg.n_leaves.value(), 1, py::arg("training_sample_size")=rows, py::arg("spherical")=spherical, py::arg("quantize_centroids")=true)
+                .attr("score_ah")(kscann_cfg.dims_per_block.value(), py::arg("anisotropic_quantization_threshold")=kscann_cfg.avq_threshold.value())
+                .attr("reorder")(1)
+                .attr("create_config")();
+            config = result.cast<std::string>();
+        } catch (const std::exception &e) {
+            LOG_KNOWHERE_WARNING_ << "KScaNN inner error: " << e.what();
+            return Status::not_implemented;
+        }
+
+        auto status = index_->Initialize(data_init, rows, config, kscann_cfg.train_thread.value());
+        if (!status.ok()) {
+            LOG_KNOWHERE_WARNING_ << "failed to initialize.";
+            return Status::index_not_trained;
+        } 
+        return Status::success;
+    }
+
+    expected<DataSetPtr> Search(const DataSet& dataset, const Config& cfg, const BitsetView& bitset) const override {
+        if (!index_) {
+            LOG_KNOWHERE_WARNING_ << "Search on empty index.";
+            return expected<DataSetPtr>::Err(Status::empty_index, "index not loaded");
+        }
+
+        auto dim = dataset.GetDim();
+        auto rows = dataset.GetRows();
+        float *data = const_cast<float *>(static_cast<const float *>(dataset.GetTensor()));
+        auto kscann_cfg = static_cast<const KscannConfig&>(cfg);
+        int closestNum = kscann_cfg.k.value();
+
+        if (kscann_cfg.metric_type.value() == "IP") {
+            for (int i = 0; i < rows; ++i) {
+                float norm = 0.0f;
+                float *tmp = data + i * dim;
+                for (int j = 0; j < dim; ++j) {
+                    norm += tmp[j] * tmp[j];
+                }
+                norm = std::sqrt(norm);
+                if (std::fabs(norm) <= std::numeric_limits<float>::epsilon()) {
+                    for (int j = 0; j < dim; ++j) {
+                        tmp[j] = 1.0f / std::sqrt(dim);
+                    }
+                } else {
+                    for (int j = 0; j < dim; ++j) {
+                        tmp[j] /= norm;
+                    }
+                }
+            }
+        }
+
+        index_->SetNumThreads(kscann_cfg.num_thread.value());
+
+        float *distances = new (std::nothrow) float[rows * closestNum]();
+        if (distances == nullptr) {
+            LOG_KNOWHERE_WARNING_ << "failed to create distances.";
+            return expected<DataSetPtr>::Err(Status::not_implemented, "Search not implemented");
+        }
+
+        int64_t *labels = new (std::nothrow) int64_t[rows * closestNum]();
+        if (labels == nullptr) {
+            delete[] distances;
+            distances = nullptr;
+            LOG_KNOWHERE_WARNING_ << "failed to create labels, free memory space.";
+            return expected<DataSetPtr>::Err(Status::not_implemented, "Search not implemented");
+        }
+
+        std::vector<float> querys(rows * (size_t)(dim));
+        for (size_t i = 0; i < rows; ++i) {
+            for (size_t j = 0; j < dim; ++j) {
+                querys[i * dim + j] = data[i * dim + j];
+            }
+        }
+        DenseDataset<float> query_data(std::move(querys), rows);
+        NNResultsVector *res = new (std::nothrow) NNResultsVector[query_data.size()];
+        if (res == nullptr) {
+            delete[] distances;
+            distances = nullptr;
+            delete[] labels;
+            labels = nullptr;
+            LOG_KNOWHERE_WARNING_ << "failed to create res, free memory space.";
+            return expected<DataSetPtr>::Err(Status::not_implemented, "Search not implemented");
+        }
+
+        auto status = index_->SearchBatched(query_data, MutableSpan<NNResultsVector>(res, query_data.size()),
+                                            closestNum, kscann_cfg.reorder.value(),
+                                            kscann_cfg.nprobe.value());
+
+        if (!status.ok()) {
+            delete[] distances;
+            distances = nullptr;
+            delete[] labels;
+            labels = nullptr;
+            delete[] res;
+            res = nullptr;
+            LOG_KNOWHERE_WARNING_ << "kscann inner error: Search not implemented.";
+            return expected<DataSetPtr>::Err(Status::not_implemented, "Search not implemented");
+        }
+
+        for (size_t i = 0; i < rows; ++i) {
+            for (size_t j = 0; j < closestNum; ++j) {
+                labels[i * closestNum + j] = res[i][j].first;
+                distances[i * closestNum + j] = res[i][j].second;
+            }
+        }
+        delete[] res;
+        res = nullptr;
+
+        auto result = GenResultDataSet(rows, closestNum, labels, const_cast<const float *>(distances));
+        return result;
+    }
+
+    expected<DataSetPtr> GetVectorByIds(const DataSet& dataset) const override {
+        return expected<DataSetPtr>::Err(Status::not_implemented, "GetVectorByIds not implemented");
+    }
+
+    bool HasRawData(const std::string& metric_type) const override {
+        // 未实现 GetVectorByIds，直接返回 false
+        return false;
+    }
+
+    expected<DataSetPtr> GetIndexMeta(const Config& cfg) const override {
+        if (!index_) {
+            LOG_KNOWHERE_WARNING_ << "get index meta on empty index.";
+            return expected<DataSetPtr>::Err(Status::empty_index, "index not loaded");
+        }
+        return expected<DataSetPtr>::Err(Status::not_implemented, "GetIndexMeta not implemented");
+    }
+
+    Status Serialize(BinarySet& binset) const override {
+        if (!index_) {
+            LOG_KNOWHERE_WARNING_ << "Can not serialize empty KScaNN index.";
+            return Status::empty_index;
+        }
+
+        uint8_t *dataPtr = nullptr;
+        size_t dataLength = 0;
+        try {
+            MemoryIOWriter writer;
+
+            if (index_->SerializeToMemory(dataPtr, dataLength) != 0) {
+                LOG_KNOWHERE_WARNING_ << "failed to serialize KScaNN index.";
+                return Status::not_implemented;
+            }
+            writer.write((char *)dataPtr, dataLength);
+            delete[] dataPtr;
+            dataPtr = nullptr;
+
+            std::shared_ptr<uint8_t[]> data(writer.data());
+            binset.Append(Type(), data, writer.tellg());
+        } catch (std::exception& e) {
+            if (dataPtr) {
+                delete[] dataPtr;
+                dataPtr = nullptr;
+            }
+            LOG_KNOWHERE_WARNING_ << "KScaNN inner error: " << e.what();
+            return Status::not_implemented;
+        }
+        return Status::success;
+    }
+
+    Status Deserialize(const BinarySet& binset, const Config& config) override {
+        if (index_) {
+            delete index_;
+            index_ = nullptr;
+            LOG_KNOWHERE_WARNING_ << "index not empty, deleted old index.";
+        }
+
+        try {
+            auto binary = binset.GetByName(Type());
+            if (binary == nullptr) {
+                LOG_KNOWHERE_WARNING_ << "Invalid binary set.";
+                return Status::invalid_binary_set;
+            }
+            indexSize_ = binary->size;
+
+            index_ = new (std::nothrow) ScannInterface();
+            if (index_ == nullptr) {
+                LOG_KNOWHERE_WARNING_ << "failed to create KScaNN index.";
+                return Status::not_implemented;
+            }
+
+            uint8_t *dataPtr = binary->data.get();
+            size_t dataLength = binary->size;
+            if (index_->LoadFromMemory(dataPtr, dataLength) != 0) {
+                LOG_KNOWHERE_WARNING_ << "failed to deserialize KScaNN index.";
+                return Status::not_implemented;
+            }
+            LOG_KNOWHERE_INFO_ << "Loaded KScaNN index.";
+        } catch (std::exception& e) {
+            LOG_KNOWHERE_WARNING_ << "KScaNN inner error: " << e.what();
+            return Status::not_implemented;
+        }
+        return Status::success;
+    }
+
+    Status DeserializeFromFile(const std::string& filename, const Config& config) override {
+        return Status::not_implemented;
+    }
+
+    std::unique_ptr<BaseConfig> CreateConfig() const override {
+        
+        return std::make_unique<KscannConfig>();
+    }
+
+    int64_t Dim() const override {
+        if (!index_) {
+            return 0;
+        }
+        return index_->GetDim();
+    }
+
+    int64_t Size() const override {
+        if (!index_) {
+            return 0;
+        }
+        return indexSize_;
+    }
+
+    int64_t Count() const override {
+        if (!index_) {
+            return 0;
+        }
+        return index_->GetNum();
+    }
+
+    std::string Type() const override {
+        return knowhere::IndexEnum::INDEX_KSCANN;
+    }
+
+    ~KscannIndexNode() override {
+        if (data_) {
+            delete[] data_;
+            data_ = nullptr;
+        }
+        if (index_) {
+            delete index_;
+            index_ = nullptr;
+        }
+    }
+
+private:
+    int64_t indexSize_;
+    ScannInterface *index_;
+    float *data_;
+};
+
+KNOWHERE_SIMPLE_REGISTER_GLOBAL(KSCANN, KscannIndexNode, fp32);
+
+}   // namespace knowhere

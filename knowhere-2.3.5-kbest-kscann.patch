+
+TEST_CASE("Test KBest Float Get Vector By Ids", "[Float GetVectorByIds]") {
+    using Catch::Approx;
+
+    const int64_t nb = 1000;
+    const int64_t nq = 100;
+    const int64_t dim = 128;
+    const int64_t search_task_num = 20;
+
+    auto metric = GENERATE(as<std::string>{}, knowhere::metric::L2);
+    auto version = GenTestVersionList();
+
+    auto base_gen = [=]() {
+        knowhere::Json json;
+        json[knowhere::meta::DIM] = dim;
+        json[knowhere::meta::METRIC_TYPE] = metric;
+        json[knowhere::meta::RETRIEVE_FRIENDLY] = true;
+        json[knowhere::meta::TOPK] = 1;
+        return json;
+    };
+
+    auto kbest_gen = [base_gen]() {
+        knowhere::Json json = base_gen();
+        json[knowhere::indexparam::KBEST_R] = 50;
+        json[knowhere::indexparam::KBEST_L] = 100;
+        json[knowhere::indexparam::KBEST_A] = 60;
+        json[knowhere::indexparam::KBEST_INIT_BUILDER_TYPE] = "RNNDescent";
+        json[knowhere::indexparam::KBEST_CONSECUTIVE] = 20;
+        json[knowhere::indexparam::KBEST_LEVEL] = 2;
+        json[knowhere::indexparam::KBEST_EFS] = 200;
+        json[knowhere::indexparam::KBEST_NUM_SEARCH_THREAD] = 1;
+        return json;
+    };
+
+    SECTION("Test float index") {
+        using std::make_tuple;
+        auto [name, gen] = GENERATE_REF(table<std::string, std::function<knowhere::Json()>>({
+            make_tuple(knowhere::IndexEnum::INDEX_KBEST, kbest_gen),
+        }));
+        auto idx = knowhere::IndexFactory::Instance().Create<knowhere::fp32>(name, version).value();
+        auto cfg_json = gen().dump();
+        CAPTURE(name, cfg_json);
+        knowhere::Json json = knowhere::Json::parse(cfg_json);
+        auto train_ds = GenDataSet(nb, dim);
+        auto train_ds_copy = CopyDataSet(train_ds, nb);
+        auto ids_ds = GenIdsDataSet(nb, nq);
+        REQUIRE(idx.Type() == name);
+        auto res = idx.Build(*train_ds, json);
+        if (!idx.HasRawData(metric)) {
+            return;
+        }
+        REQUIRE(res == knowhere::Status::success);
+        knowhere::BinarySet bs;
+        idx.Serialize(bs);
+
+        auto idx_new = knowhere::IndexFactory::Instance().Create<knowhere::fp32>(name, version).value();
+        idx_new.Deserialize(bs);
+
+        auto retrieve_task = [&]() {
+            auto results = idx_new.GetVectorByIds(*ids_ds);
+            REQUIRE(results.has_value());
+            auto xb = (float*)train_ds_copy->GetTensor();
+            auto res_rows = results.value()->GetRows();
+            auto res_dim = results.value()->GetDim();
+            auto res_data = (float*)results.value()->GetTensor();
+            REQUIRE(res_rows == nq);
+            REQUIRE(res_dim == dim);
+            for (int i = 0; i < nq; ++i) {
+                const auto id = ids_ds->GetIds()[i];
+                for (int j = 0; j < dim; ++j) {
+                    REQUIRE(res_data[i * dim + j] == xb[id * dim + j]);
+                }
+            }
+        };
+
+        std::vector<std::future<void>> retrieve_task_list;
+        for (int i = 0; i < search_task_num; i++) {
+            retrieve_task_list.push_back(std::async(std::launch::async, [&] { return retrieve_task(); }));
+        }
+        for (auto& task : retrieve_task_list) {
+            task.wait();
+        }
+    }
+}

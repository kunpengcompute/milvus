+#ifndef KSCANN_CONFIG_H
+#define KSCANN_CONFIG_H
+
+#include "knowhere/comp/index_param.h"
+#include "knowhere/config.h"
+
+namespace knowhere {
+
+class KscannConfig : public BaseConfig {
+public:
+    CFG_INT n_leaves;
+    CFG_INT dims_per_block;
+    CFG_FLOAT avq_threshold;
+    CFG_FLOAT soar_lambda;
+    CFG_FLOAT overretrieve_factor;
+    CFG_INT train_thread;
+    
+    CFG_INT nprobe;
+    CFG_INT reorder;
+    CFG_FLOAT adp_threshold;
+    CFG_INT adp_refined;
+    CFG_INT num_thread;
+    CFG_INT batch_size;
+
+    KNOHWERE_DECLARE_CONFIG(KscannConfig) {
+        KNOWHERE_CONFIG_DECLARE_FIELD(n_leaves)
+            .description("kscann leaf node")
+            .set_default(2000)
+            .for_train();
+        KNOWHERE_CONFIG_DECLARE_FIELD(dims_per_block)
+            .description("kscann dims per block")
+            .set_default(4)
+            .for_train();
+        KNOWHERE_CONFIG_DECLARE_FIELD(avq_threshold)
+            .description("kscann avq threshold")
+            .allow_empty_without_default()
+            .for_train();
+        KNOWHERE_CONFIG_DECLARE_FIELD(soar_lambda)
+            .description("kscann soar lambda")
+            .allow_empty_without_default()
+            .for_train();
+        KNOWHERE_CONFIG_DECLARE_FIELD(overretrieve_factor)
+            .description("kscann overretrieve factor")
+            .allow_empty_without_default()
+            .for_train();
+        KNOWHERE_CONFIG_DECLARE_FIELD(train_thread)
+            .description("kscann train thread")
+            .set_default(kHardwareConcurrency)
+            .for_train();
+        KNOWHERE_CONFIG_DECLARE_FIELD(nprobe)
+            .description("kscann nprobe")
+            .set_default(200)
+            .set_range(1, n_leaves.value())
+            .for_search();
+        KNOWHERE_CONFIG_DECLARE_FIELD(reorder)
+            .description("kscann reorder")
+            .set_default(900)
+            .set_range(k.value(), std::numeric_limits<CFG_INT::value_type>::max())
+            .for_search();
+        KNOWHERE_CONFIG_DECLARE_FIELD(adp_threshold)
+            .description("kscann adp_threshold")
+            .set_default(0.2)
+            .set_range(0, 0.8)
+            .for_search();
+        KNOWHERE_CONFIG_DECLARE_FIELD(adp_refined)
+            .description("kscann adp_refined")
+            .set_default(0)
+            .set_range(0, nprobe.value())
+            .for_search();
+        KNOWHERE_CONFIG_DECLARE_FIELD(num_thread)
+            .description("kscann num_thread")
+            .set_default(1)
+            .set_range(1, std::numeric_limits<CFG_INT::value_type>::max())
+            .for_search();
+        KNOWHERE_CONFIG_DECLARE_FIELD(batch_size)
+            .description("kscann batch size")
+            .set_default(1)
+            .set_range(1, std::numeric_limits<CFG_INT::value_type>::max())
+            .for_search();
+    }
+
+    Status
+    CheckAndAdjust(PARAM_TYPE param_type, std::string* err_msg) override {
+        switch (param_type) {
+            case PARAM_TYPE::TRAIN: {
+                if (!avq_threshold.has_value()) {
+                    avq_threshold = std::numeric_limits<float>::quiet_NaN();
+                }
+
+                if (!soar_lambda.has_value()) {
+                    soar_lambda = -1;
+                } else if (soar_lambda.value() <= 0 && soar_lambda.value() != -1) {
+                    *err_msg = "soar_lambda(" + std::to_string(soar_lambda.value()) +
+                               ") should be greater than 0 or equal to -1";
+                    LOG_KNOWHERE_ERROR_ << *err_msg;
+                    return Status::out_of_range_in_json;
+                }
+                if (!overretrieve_factor.has_value()) {
+                    overretrieve_factor = -1;
+                } else if ((overretrieve_factor.value() < 1 || overretrieve_factor.value() > 2) && overretrieve_factor.value() != -1) {
+                    *err_msg = "overretrieve_factor(" + std::to_string(overretrieve_factor.value()) +
+                               ") should be [1, 2] or equal to -1";
+                    LOG_KNOWHERE_ERROR_ << *err_msg;
+                    return Status::out_of_range_in_json;
+                }
+            }
+            default:
+                break;
+        }
+        return Status::success;
+    }
+};
+}   // namespace knowhere
+
+#endif	/* KSCANN_CONFIG_H*/
